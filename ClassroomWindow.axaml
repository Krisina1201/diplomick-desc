<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Diplom"
        xmlns:models="clr-namespace:Diplom.Models"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="Diplom.ClassroomWindow"
        WindowStartupLocation="CenterScreen"
        Title="Управление аудиториями"
        Background="#f5f5f5">


	<Grid Margin="20" RowDefinitions="Auto,Auto,*">
		<!-- Заголовок -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
			<TextBlock Text="Аудитории" Classes="header" VerticalAlignment="Center"/>
		</StackPanel>

		<!-- Панель инструментов -->
		<Border Grid.Row="1" Classes="card" Padding="15" Margin="0,0,0,20">
			<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
				<ComboBox x:Name="sortByTitle"
                          PlaceholderText="Сортировка по номеру"
						  VerticalAlignment="Center"
						  SelectionChanged="ComboBox_SelectionChanged">
					<ComboBoxItem>По убыванию</ComboBoxItem>
					<ComboBoxItem>По возрастанию</ComboBoxItem>
				</ComboBox>

				<Button Content="Добавить аудиторию"
                        Click="AddClassroom_Click"/>

				<Button Content="Назад"
                        Click="BackButton_Click"
                        Classes="secondary"/>
			</StackPanel>
		</Border>

		<!-- Список аудиторий -->
		<ListBox x:Name="ClassroomListBox" Grid.Row="2" HorizontalAlignment="Center">
			<ListBox.ItemsPanel>
				<ItemsPanelTemplate>
					<WrapPanel Orientation="Horizontal" HorizontalAlignment="Stretch"/>
				</ItemsPanelTemplate>
			</ListBox.ItemsPanel>

			<ListBox.ItemTemplate>
				<DataTemplate DataType="models:Classroom">
					<Border Classes="card" Width="350" Margin="10" Padding="15">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>

							<!-- Статус и номер -->
							<!-- Фрагмент с исправлением для IsActive -->
							<Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
								<Border Background="#4CAF50"
										CornerRadius="4"
										Padding="8,4"
										HorizontalAlignment="Left">
									<Border.IsVisible>
										<Binding Path="IsActive"/>
									</Border.IsVisible>
									<TextBlock Text="Активна" Foreground="White" FontSize="12"/>
								</Border>
								<Border Background="#F44336"
										CornerRadius="4"
										Padding="8,4"
										HorizontalAlignment="Left">
									<Border.IsVisible>
										<Binding Path="IsActive">
											<Binding.Converter>
												<local:InverseBoolConverter/>
											</Binding.Converter>
										</Binding>
									</Border.IsVisible>
									<TextBlock Text="Неактивна" Foreground="White" FontSize="12"/>
								</Border>
								<TextBlock Grid.Column="1"
										   Text="{Binding RoomNumber}"
										   FontSize="18"
										   FontWeight="Bold"
										   Foreground="#283593"/>
							</Grid>

							<!-- Название -->
							<TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{Binding RoomName}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

							<!-- Ответственный -->
							<StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,5">
								<TextBlock Text="Ответственный:" FontWeight="Bold" Margin="0,0,5,0"/>
								<TextBlock Text="{Binding Responsible.LastName}"/>
								<TextBlock Text=" "/>
								<TextBlock Text="{Binding Responsible.FirstName}"/>
							</StackPanel>

							<!-- Вместимость -->
							<StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,5">
								<TextBlock Text="Вместимость:" FontWeight="Bold" Margin="0,0,5,0"/>
								<TextBlock Text="{Binding Capacity}"/>
								<TextBlock Text=" чел."/>
							</StackPanel>

							<!-- Описание -->
							<StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,15"
                                        IsVisible="{Binding Description, Converter={x:Static local:NotNullToBoolConverter.Instance}}">
								<TextBlock Text="Описание:" FontWeight="Bold" Margin="0,0,0,3"/>
								<TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
							</StackPanel>

							<!-- Кнопки -->
							<StackPanel Grid.Row="0" Grid.Column="1"
                                        Grid.RowSpan="5"
                                        Orientation="Vertical"
                                        VerticalAlignment="Bottom">
								<Button Content="Редактировать"
                                        CommandParameter="{Binding}"
                                        Click="EditClassroom_Click"
                                        Margin="5"
                                        Padding="12,6"/>
								<Button Content="Удалить"
                                        CommandParameter="{Binding}"
										HorizontalAlignment="Stretch"
										Margin="5"
                                        Click="DeleteClassroom_Click"
                                        Classes="danger"
                                        Padding="12,6"/>
							</StackPanel>
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>
</Window>