<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="400"
        x:Class="Diplom.MainWindow"
        WindowStartupLocation="CenterScreen"
        Title="Авторизация"
        Width="350"
        Height="400"
        CanResize="False"
        Background="#f5f5f5">

	<Border Background="White"
            CornerRadius="12"
            Margin="20"
            Padding="30"
		    BoxShadow="0 4 12 0 #26000000">

		<StackPanel VerticalAlignment="Center" Spacing="25">
			<!-- Логотип/Заголовок -->
			<TextBlock Text="FunkyPop"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#283593"
                       HorizontalAlignment="Center"/>

			<TextBlock Text="Вход в систему"
                       FontSize="18"
                       Foreground="#757575"
                       HorizontalAlignment="Center"/>

			<!-- Поле ввода пароля -->
			<StackPanel Spacing="8">
				<TextBlock Text="Пароль"
                           FontSize="14"
                           Foreground="#212121"/>
				<TextBox x:Name="passwordBox"
                         PasswordChar="●"
                         Watermark="Введите пароль"
                         Height="45"/>
			</StackPanel>

			<!-- Кнопка входа -->
			<Button Content="Войти"
                    Click="EntranceClick"
                    Height="45"
                    FontSize="16"
                    Background="#283593"
                    Foreground="White"
                    CornerRadius="4"/>
		</StackPanel>
	</Border>
</Window>