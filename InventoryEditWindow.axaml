<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="700"
        x:Class="Diplom.InventoryEditWindow"
        Title="Редактирование инвентаря"
        Width="500"
		xmlns:models="clr-namespace:Diplom.Models"
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#f5f5f5">

	<Border Classes="card" Margin="20" Padding="20">
		<Grid RowDefinitions="Auto,*,Auto">
			<!-- Заголовок -->
			<TextBlock Grid.Row="0"
                       Text="Информация об инвентаре"
                       Classes="header"
                       Margin="0,0,0,20"/>

			<!-- Форма -->
			<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
				<StackPanel Spacing="15">
					<StackPanel>
						<TextBlock Text="Наименование предмета" FontWeight="SemiBold" Margin="0,0,0,5"/>
						<TextBox x:Name="ItemNameTextBox" Watermark="Введите наименование"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Тип инвентаря" FontWeight="SemiBold" Margin="0,0,0,5"/>
						<ComboBox x:Name="ItemTypeComboBox"
                                  PlaceholderText="Выберите тип инвентаря"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Аудитория" FontWeight="SemiBold" Margin="0,0,0,5"/>
						<ComboBox x:Name="ClassroomComboBox"
                                  PlaceholderText="Выберите аудиторию"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Производитель" FontWeight="SemiBold" Margin="0,0,0,5"/>
						<TextBox x:Name="ManufacturerTextBox" Watermark="Введите производителя"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Модель" FontWeight="SemiBold" Margin="0,0,0,5"/>
						<TextBox x:Name="ModelTextBox" Watermark="Введите модель"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Инвентарный номер" FontWeight="SemiBold" Margin="0,0,0,5"/>
						<TextBox x:Name="InventoryNumberTextBox"
                                 Watermark="Введите инвентарный номер"
                                 Text="0"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Описание состояния" FontWeight="SemiBold" Margin="0,0,0,5"/>
						<TextBox x:Name="ConditionDescriptionTextBox"
                                 Watermark="Введите описание состояния"
                                 Height="60"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Дата покупки" FontWeight="SemiBold" Margin="0,0,0,5"/>
						<DatePicker x:Name="PurchaseDatePicker"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Гарантия до" FontWeight="SemiBold" Margin="0,0,0,5"/>
						<DatePicker x:Name="WarrantyUntilPicker"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Примечания" FontWeight="SemiBold" Margin="0,0,0,5"/>
						<TextBox x:Name="NotesTextBox"
                                 Watermark="Введите примечания"
                                 Height="60"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"/>
					</StackPanel>
				</StackPanel>
			</ScrollViewer>

			<!-- Кнопки и статус -->
			<StackPanel Grid.Row="2" Spacing="10">
				<TextBlock x:Name="StatusTextBlock"
                           Classes="status"
                           TextWrapping="Wrap"/>

				<Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
					<Button Grid.Column="0"
                            Content="Сохранить"
                            Click="SaveButton_Click"
                            Margin="0,0,5,0"/>
					<Button Grid.Column="1"
                            Content="Отмена"
                            Click="CancelButton_Click"
                            Classes="secondary"/>
				</Grid>
			</StackPanel>
		</Grid>
	</Border>
</Window>