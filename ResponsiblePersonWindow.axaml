<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Diplom"
        xmlns:models="clr-namespace:Diplom.Models"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="Diplom.ResponsiblePersonWindow"
        WindowStartupLocation="CenterScreen"
        Title="Управление сотрудниками"
        Background="#f5f5f5">


	<Grid Margin="20" RowDefinitions="Auto,Auto,*">
		<!-- Заголовок -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
			<TextBlock Text="Сотрудники" Classes="header" VerticalAlignment="Center"/>
		</StackPanel>

		<!-- Панель инструментов -->
		<Border Grid.Row="1" Classes="card" Padding="15" Margin="0,0,0,20">
			<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
				<Button Content="Добавить сотрудника"
                        Click="AddResponsible_Click"/>

				<Button Content="Назад"
                        Click="BackButton_Click"
                        Classes="secondary"/>
			</StackPanel>
		</Border>

		<!-- Список сотрудников -->
		<ListBox x:Name="ResponsibleListBox" Grid.Row="2">
			<ListBox.ItemTemplate>
				<DataTemplate DataType="models:ResponsiblePerson">
					<Border Classes="card" Margin="10" Padding="20">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>

							<!-- ФИО -->
							<TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
								<Run Text="{Binding LastName}" FontSize="18" FontWeight="Bold" Foreground="#283593"/>
								<Run Text=" " FontSize="18" FontWeight="Bold"/>
								<Run Text="{Binding FirstName}" FontSize="18" FontWeight="Bold" Foreground="#283593"/>
								<Run Text=" " FontSize="18" FontWeight="Bold"/>
								<Run Text="{Binding MiddleName}" FontSize="18" FontWeight="Bold" Foreground="#283593"/>
							</TextBlock>

							<!-- Должность -->
							<Border Grid.Row="1" Grid.Column="0"
                                    Background="#e8eaf6"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Left">
								<TextBlock Text="{Binding Position}" Foreground="#283593"/>
							</Border>

							<!-- Контакты -->
							<WrapPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,10">
								<Border Background="#f0f0f0" CornerRadius="4" Padding="8,4" Margin="0,0,5,5">
									<TextBlock Text="{Binding Phone}"/>
								</Border>
								<Border Background="#f0f0f0" CornerRadius="4" Padding="8,4" Margin="0,0,5,5">
									<TextBlock Text="{Binding Email}"/>
								</Border>
								<Border Background="#f0f0f0" CornerRadius="4" Padding="8,4" Margin="0,0,5,5">
									<StackPanel Orientation="Horizontal">
										<TextBlock Text="Аудиторий: "/>
										<TextBlock Text="{Binding Classrooms.Count}"/>
									</StackPanel>
								</Border>
							</WrapPanel>

							<!-- Кнопки -->
							<StackPanel Grid.Row="0" Grid.Column="1"
                                        Grid.RowSpan="3"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
								<Button Content="Редактировать"
                                        CommandParameter="{Binding}"
                                        Click="EditResponsible_Click"
                                        Margin="0,0,5,0"/>
								<Button Content="Удалить"
                                        CommandParameter="{Binding}"
                                        Click="DeleteResponsible_Click"
                                        Classes="danger"/>
							</StackPanel>
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>
</Window>